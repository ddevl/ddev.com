---
/**
 * The DDEV Foundation postal address and phone, used on the contact, privacy,
 * and foundation pages. Pulls values from `src/const.ts` so they live in one
 * place.
 */
import {
  ORG_NAME,
  ORG_STREET,
  ORG_CITY,
  ORG_STATE_ABBR,
  ORG_POSTAL_CODE,
  ORG_COUNTRY,
  ORG_PHONE,
} from "../const"
---

<address class="not-italic">
  <div class="font-semibold">{ORG_NAME}</div>
  <div>{ORG_STREET}</div>
  <div>{ORG_CITY}, {ORG_STATE_ABBR} {ORG_POSTAL_CODE} {ORG_COUNTRY}</div>
  <div class="mt-2">
    <span class="font-medium">Phone:</span> <a href={`tel:${ORG_PHONE}`}>{ORG_PHONE}</a>
  </div>
</address>
